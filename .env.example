# Salin file ini jadi ".env" (untuk coba lokal) lalu isi key Gemini kamu.
# JANGAN pernah commit file ".env" ke GitHub / share isinya ke siapapun.
# Ambil API key baru di: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=isi_api_key_gemini_kamu_disini

# ---- Firebase config (ambil dari Firebase Console > Project settings > Web app) ----
# Nilai-nilai ini AMAN untuk dipublish/di-deploy (beda dari Gemini API key di atas).
# Keamanan datanya diatur lewat Firestore Security Rules, bukan dengan sembunyikan config ini.
VITE_FIREBASE_API_KEY=isi_disini
VITE_FIREBASE_AUTH_DOMAIN=nama-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nama-project
VITE_FIREBASE_STORAGE_BUCKET=nama-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=isi_disini
VITE_FIREBASE_APP_ID=isi_disini
